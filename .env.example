# Host folder containing your photos. An Unraid example is /mnt/user/photos/framefeed.
PHOTO_DIR_HOST=./data/photos
FRAMEFEED_PORT=8080
FRAMEFEED_TAG=latest

# Container file ownership. Unraid normally uses PUID=99 and PGID=100.
PUID=1000
PGID=1000

# See presets/ for known display sizes.
FRAME_WIDTH=1600
FRAME_HEIGHT=1200

# A normal photo stays up for one hour. A newly discovered photo gets 65 minutes.
ROTATION_SECONDS=3600
NEW_PHOTO_HOLD_SECONDS=3900
SCAN_INTERVAL_SECONDS=300
ALBUM_SYNC_INTERVAL_SECONDS=900

# Avoid aggressive crops when the camera and frame orientations differ.
MIN_CROP_RETAINED_FRACTION=0.75
FACE_DETECTOR=yunet
FACE_MIN_SCORE=0.30
FACE_MARGIN_RATIO=0.75
ANALYSIS_BATCH_SIZE=8

# Optional advanced mode: FACE_DETECTOR=immich and your private ML endpoint.
FACE_ANALYSIS_URL=
FACE_MODEL=buffalo_l
LOG_LEVEL=INFO
